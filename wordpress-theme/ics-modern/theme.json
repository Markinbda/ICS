{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "color": {
      "palette": [
        { "name": "ICS Yellow", "slug": "ics-yellow", "color": "#f4bf00" },
        { "name": "ICS Navy", "slug": "ics-navy", "color": "#0d2a4a" },
        { "name": "ICS Ink", "slug": "ics-ink", "color": "#102033" },
        { "name": "ICS Steel", "slug": "ics-steel", "color": "#4b5d73" },
        { "name": "Background", "slug": "ics-bg", "color": "#f7f9fc" },
        { "name": "White", "slug": "white", "color": "#ffffff" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Barlow Condensed', sans-serif",
          "name": "Barlow Condensed",
          "slug": "barlow-condensed"
        },
        {
          "fontFamily": "'Manrope', sans-serif",
          "name": "Manrope",
          "slug": "manrope"
        }
      ],
      "fluid": true
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.4,
        "steps": 6,
        "mediumStep": 1.2,
        "unit": "rem"
      },
      "units": ["px", "rem", "em", "%", "vw", "vh"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--ics-ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--manrope)",
      "lineHeight": "1.55"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
          "fontWeight": "700",
          "textTransform": "uppercase",
          "lineHeight": "1.05"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--ics-yellow)",
          "text": "#111111"
        },
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "right": "18px",
            "bottom": "12px",
            "left": "18px"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--ics-navy)"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
